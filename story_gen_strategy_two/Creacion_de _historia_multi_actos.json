      "id": "e1168358-f81b-4bba-961d-205bb76538fb",
      "name": "Generate Summary"
    },
    {
      "parameters": {
        "jsCode": "const split = $items(\"Split In Batches\")[0].json;\nconst story_config = $items(\"Story_prompt\")[0].json.data;\nconst system_prompt = $items(\"System_prompt\")[0].json.data;\n\nconst acto = String($json.data || '');\nconst previous_summary =\n  $items(\"Read Previous Summary\")[0]?.json?.data || '';\n\nconst body = {\n  model: \"llama3.1:8b\",\n  stream: false,\n  system: system_prompt,\n  prompt: `\n${story_config}\n\n==============================\nESTADO ANTERIOR (NO MODIFICAR IDENTIDAD)\n==============================\n${previous_summary}\n\n==============================\nINSTRUCCIONES OBLIGATORIAS\n==============================\n1. NO cambies nombres.\n2. NO cambies edades.\n3. NO elimines personajes existentes.\n4. NO re-narres actos anteriores.\n5. NO borres eventos previos.\n6. SOLO actualiza el estado agregando lo ocurrido en este acto.\n\nSi modificas identidad fija, el resultado es inválido.\n\nDevuelve SOLO esta estructura:\n\nIDENTIDAD FIJA:\n(listado exacto)\n\nEVENTOS ACUMULADOS:\n(lista numerada acumulativa)\n\nESTADO ACTUAL DEL PROTAGONISTA:\n(descripción breve)\n\n==============================\nACTO NUEVO\n==============================\n${acto}\n`\n};\n\nreturn [{\n  json: {\n    acto_numero: split.acto_numero,\n    story_id: split.story_id,\n    ...body\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2624,
        496
      ],
      "id": "1e8a4533-7e99-4fb5-b42d-e7baec4a91e7",
      "name": "Build Summary prompt"
    },
    {
      "parameters": {
        "jsCode": "const text = $json.response || '';\n\n// Recuperar datos del nodo Build Prompt\nconst buildData = $items(\"Build Prompt\")[0].json;\n\nconst acto_numero = buildData.acto_numero;\nconst story_id = buildData.story_id;\n\nreturn [{\n  json: {\n    acto_numero,\n    story_id\n  },\n  binary: {\n    data: {\n      data: Buffer.from(text, 'utf8').toString('base64'),\n      mimeType: 'text/markdown',\n      fileName: `acto_${acto_numero}.md`\n    }\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2016,
        352
      ],
      "id": "53e0180e-ff12-4276-8aca-0eef838b4755",
      "name": "Write file acto md"
    },
    {
      "parameters": {
        "jsCode": "const text = $json.response || '';\n\n// Traemos datos desde el nodo anterior al HTTP\nconst previous = $items(\"Build Prompt\")[0].json;\n\nconst acto_numero = previous.acto_numero;\nconst story_id = previous.story_id;\n\nreturn [{\n  json: {  \n    acto_numero,\n    story_id\n  },\n  binary: {\n    data: {\n      data: Buffer.from(text, 'utf8').toString('base64'),\n      mimeType: 'text/markdown',\n      fileName: `acto_${acto_numero}_resumen.md`\n    }\n  }\n}];\n"
      },
