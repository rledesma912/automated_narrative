    {
      "parameters": {
        "jsCode": "let system_prompt = '';\nlet story_config = '';\nlet previous_summary = '';\n\n// Recorrer todos los items del Merge (Append)\nfor (const item of $input.all()) {\n\n  const data = item.json.data;       // para system y config\n  const content = item.json.content; // para resumen\n\n  if (data) {\n    // Detectar cuál es cuál por contenido\n    if (data.includes('REGLAS OBLIGATORIAS')) {\n      system_prompt = data;\n    } else if (data.includes('# CONFIGURACIÓN GLOBAL')) {\n      story_config = data;\n    }\n  }\n\n  if (content !== undefined) {\n    previous_summary = content;\n  }\n}\n\n// Obtener datos del Split\nconst splitItem = $items(\"Split In Batches\")[0].json;\nconst acto_numero = splitItem.acto_numero;\nconst story_id = splitItem.story_id;\n\n// Construcción del prompt\nlet prompt = `\n${story_config}\n`;\n\nif (previous_summary) {\n  prompt += `\n==============================\nESTADO ACTUAL DE LA HISTORIA\n==============================\n${previous_summary}\n\nREGLAS ESTRICTAS:\n- No cambies nombres ni edades.\n- No introduzcas nuevos protagonistas.\n- No redescubras eventos ya ocurridos.\n- No contradigas eventos acumulados.\n- Si la tumba ya fue descubierta, no puede volver a descubrirse.\n- Continúa exactamente desde el estado actual.\n`;\n}\n\nprompt += `\n==============================\nINSTRUCCIÓN\n==============================\nGenera el Acto ${acto_numero}.\nNo resuelvas la historia si no es el último acto.\nEscala la tensión progresivamente.\n`;\n\nreturn [{\n  json: {\n    acto_numero,\n    story_id,\n    prompt,\n    system_prompt\n  }\n}];\n"
      },
