      "parameters": {
        "filePath": "=/home/node/.n8n-files/prompts/historias/{{$json.story_id}}/acto_{{$json.acto_numero -1}}_resumen.md"
      },
      "id": "3721dd2f-df3f-467e-87be-15c56dff4920",
      "name": "Read Previous Summary",
      "type": "n8n-nodes-base.readBinaryFile",
      "typeVersion": 1,
