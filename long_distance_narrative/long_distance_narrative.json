    {
      "parameters": {
        "jsCode": "// Aquí recibimos el array de filas de la base de datos\nconst filas = $input.all();\n\nif (filas.length === 0) {\n    throw new Error(\"No se encontraron actos en la base de datos para este ID.\");\n}\n\n// Unimos los textos\nconst historiaCompleta = filas.map((fila, index) => {\n  return `## ACTO ${index + 1}\\n\\n${fila.json.contenido}`;\n}).join(\"\\n\\n---\\n\\n\");\n\nreturn [{\n  json: {\n    historia_final: \"# RELATO COMPLETO\\n\\n\" + historiaCompleta,\n    nombre_archivo: `relato_final_${Date.now()}.md`\n  }\n}];"
      },
