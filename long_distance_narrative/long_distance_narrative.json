    {
      "parameters": {
        "jsCode": "const previousState = $node[\"get_current_act\"].json;\n\n// Texto narrativo del acto recién generado\nconst textoActo = $node[\"Basic LLM Chain\"].json.text;\n\n// Memoria estructurada generada\nconst memoriaEstructurada = $node[\"generate_structured_memory\"].json.text;\n\nconst nextAct = previousState.acto_actual + 1;\n\nreturn [{\n  json: {\n    ...previousState,\n    acto_actual: nextAct,\n\n    // ACUMULACIÓN REAL NARRATIVA\n    resumen_narrativo_acumulado: \n      (previousState.resumen_narrativo_acumulado || \"\") \n      + \"\\n\\n\" \n      + textoActo,\n\n    // ACUMULACIÓN DE MEMORIA ESTRUCTURADA\n    memoria_estructurada_acumulada:\n      (previousState.memoria_estructurada_acumulada || \"\")\n      + \"\\n\\n---\\n\\n\"\n      + memoriaEstructurada\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
