    {
      "parameters": {
        "jsCode": "// 1. Obtenemos los dos ítems que vienen del nodo Extract From File\nconst items = $input.all();\n\n// 2. Buscamos cuál es el sistema y cuál es la historia basándonos en palabras clave del contenido\n// (Como no tenemos el fileName aquí, buscamos por texto interno)\nconst sistemaItem = items.find(i => i.json.data.includes(\"# ROLE\") || i.json.data.includes(\"STYLE RULES\"));\nconst historiaItem = items.find(i => i.json.data.includes(\"# CONCEPTO\") || i.json.data.includes(\"ESTRUCTURA\"));\n\nconst sistema = sistemaItem ? sistemaItem.json.data : \"Error: No se encontró el System Prompt\";\nconst historia = historiaItem ? historiaItem.json.data : \"Error: No se encontró la Historia Base\";\n\n// 3. Inicializamos todo para el Acto 1\nreturn [{\n  json: {\n    acto_actual: 1,\n    total_actos: 5,\n    sistema_text: sistema,\n    historia_base_text: historia,\n    resumen_narrativo_acumulado: \"\",\n    memoria_estructurada_acumulada: \"\",\n    story_id: \"terror_\" + Date.now(),\n    // Esta variable ayudará a extraer la misión del acto más adelante\n    mision_del_acto: \"\" \n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        -160
      ],
      "id": "9cf8bd54-6892-4286-87e0-82f1de590155",
      "name": "init_story_state"
    },
    {
      "parameters": {
        "jsCode": "// Recuperamos los datos del nodo de Setup (o del loop)\nconst input = $input.item.json;\nconst historiaCompleta = input.historia_base_text;\nconst actoNum = input.acto_actual;\n\n// Regex para encontrar el Acto X y capturar su descripción\n// Busca patrones como \"1. **Acto 1 (Introducción)**: Texto...\"\nconst regex = new RegExp(`${actoNum}\\\\.\\\\s+\\\\*\\\\*Acto\\\\s+${actoNum}\\\\s+\\\\(.*?\\\\)\\\\*\\\\*:\\\\s+(.*?)(?=\\\\n\\\\d+\\\\.|$)`, 'is');\nconst match = historiaCompleta.match(regex);\n\n// Extraemos la instrucción. Si no la encuentra, da un mensaje de error claro.\nconst misionExtraida = match ? match[1].trim() : \"No se encontró instrucción específica para este acto.\";\n\n// Retornamos todo lo anterior MAS la misión específica de esta vuelta\nreturn {\n  ...input,\n  mision_del_acto: misionExtraida\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -256,
        -80
      ],
      "id": "561699b2-6d6c-4116-97ef-0abfa2f7e8c4",
      "name": "get_current_act"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.sistema_text }}\n\n---\n\nCONTEXTO FIJO DE LA HISTORIA:\n{{ $json.historia_base_text }}\n\n---\nRESUMEN NARRATIVO ACUMULADO:\n{{ $json.resumen_narrativo_acumulado }}\n\n---\n\nMEMORIA ESTRUCTURADA:\n{{ $json.memoria_estructurada_acumulada }}\n\n---\n\nMISIÓN ESPECÍFICA DEL ACTO {{ $json.acto_actual }}:\n{{ $json.mision_del_acto }}\n\n---\n\nINSTRUCCIONES FINALES (OBLIGATORIAS):\n\n1. Escribe entre 450 y 550 palabras.\n2. Solo relato continuo.\n3. No incluyas títulos, reglas ni comentarios.\n4. No agregues personajes nuevos.\n5. Respeta estrictamente los hechos confirmados.\n6. No expliques nada fuera de la narración.\n7. No repitas información literal del resumen.",
        "messages": {
          "messageValues": [
            {
              "message": "={{ $json.sistema_text }}"
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -96,
        -80
      ],
