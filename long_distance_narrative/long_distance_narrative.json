        64
      ],
      "id": "3cc72519-c324-4bb0-94d1-646421f16687",
      "name": "Ollama Chat Model",
      "credentials": {
        "ollamaApi": {
          "id": "pme8Qn9prOFIVslx",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 1. Recogemos lo que escribió Ollama (en este nodo es .text)\n// Usamos el operador ? para evitar que el flujo explote si viene vacío\nconst storyText = $node[\"Basic LLM Chain\"].json.text || \"\"; \n\n// 2. Traemos el estado que venía del paso anterior al LLM\nconst currentState = $node[\"get_current_act\"].json;\n\n// 3. Incrementamos el acto\nconst nextAct = currentState.acto_actual + 1;\n\n// 4. Retornamos el nuevo estado actualizado\nreturn [{\n  json: {\n    ...currentState,\n    acto_actual: nextAct,\n    // Guardamos el final de lo que escribió como resumen para el siguiente acto\n    resumen_acumulado: \"Anteriormente: \" + storyText.substring(Math.max(0, storyText.length - 800)),\n    ultimo_relato: storyText\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
