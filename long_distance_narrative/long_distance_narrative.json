    {
      "parameters": {
        "jsCode": "const previousState = $node[\"get_current_act\"].json;\n\n// Texto narrativo del acto recién generado (ya no lo usamos para acumular)\nconst textoActo = $node[\"generar_acto_del_relato\"].json.text;\n\n// Ahora usamos el resumen generado por el nuevo nodo\nconst resumenCorto = $node[\"summarize_act\"].json.text;  // Ajusta \"summarize_act\" al nombre que le pusiste\n\n// Memoria estructurada generada\nconst memoriaEstructurada = $node[\"generate_structured_memory\"].json.text;\n\nconst nextAct = previousState.acto_actual + 1;\n\nreturn [{\n  json: {\n    ...previousState,\n    acto_actual: nextAct,\n\n    // ACUMULACIÓN DE RESUMEN NARRATIVO CORTO\n    resumen_narrativo_acumulado: \n    (previousState.resumen_narrativo_acumulado || \"\") \n    + \"\\n\\nActo \" + previousState.acto_actual + \" (resumen clave – enlaza y varía en próximo, mantén flujo coherente): \" + resumenCorto,\n    \n    // ACUMULACIÓN DE MEMORIA ESTRUCTURADA (sin cambios)\n    memoria_estructurada_acumulada:\n      (previousState.memoria_estructurada_acumulada || \"\")\n      + \"\\n\\n---\\n\\n\"\n      + memoriaEstructurada\n  }\n}];"
      },
