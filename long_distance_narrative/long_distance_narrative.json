    {
      "parameters": {
        "jsCode": "const items = $input.all();  // Rows de SQL\n\nconst storyId = $node[\"init_story_state\"].json.story_id;\n\nlet md = \"# RELATO COMPLETO\\n\\n\";\n\nitems.forEach(item => {\n  md += \"## ACTO \" + item.json.acto_numero + \"\\n\\n\";\n  md += item.json.contenido + \"\\n\\n---\\n\\n\";\n});\n\nreturn [{\n  json: {\n    md_text: md,\n    story_id: storyId,\n    nombre_archivo: storyId + \"_relato_completo.md\"\n  }\n}];"
      },
