    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n\n  const base = item.json.base_context;\n\n  return {\n    json: {\n      id_story: base.id_story,\n      story_name: base.story_name,\n\n      total_acts: base.total_acts,\n      act_number: item.json.act_number,\n      arc_phase: item.json.arc_phase,\n\n      act_mission: item.json.act_mission,\n\n      system_prompt: base.system_prompt,\n      story_context: base.story_context,\n\n      accumulated_summary: \"\",\n      accumulated_memory: \"\"\n    }\n  };\n\n});"
      },
