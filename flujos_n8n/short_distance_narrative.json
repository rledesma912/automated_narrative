    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet sistema = \"\";\nlet historia = \"\";\nlet estados = \"\";\nlet config = {};\n\n// 1️⃣ obtener configuración primero\nfor (const item of items) {\n  if (item.json && item.json.total_acts) {\n    config = item.json;\n    break;\n  }\n}\n\n// 2️⃣ procesar archivos binarios\nfor (let i = 0; i < items.length; i++) {\n\n  const item = items[i];\n\n  if (item.binary && item.binary.data) {\n\n    const fileName = item.binary.data.fileName || \"\";\n\n    const buffer = await this.helpers.getBinaryDataBuffer(i, \"data\");\n    const text = buffer.toString(\"utf8\").trim();\n\n    if (fileName === config.system_prompt_file) {\n      sistema = text;\n      continue;\n    }\n\n    if (fileName === config.story_prompt_file) {\n      historia = text;\n      continue;\n    }\n\n    if (fileName === config.extract_prompt_file) {\n      estados = text;\n      continue;\n    }\n\n  }\n}\n\nreturn [{\n  json: {\n    id_story: config.id_story,\n    story_name: config.story_name,\n    total_acts: config.total_acts,\n    system_prompt: sistema,\n    story_prompt: historia,\n    extract_prompt: estados,\n    accumulated_summary: \"\",\n    accumulated_memory: \"\"\n  }\n}];"
      },
