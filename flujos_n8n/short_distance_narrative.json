    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst storyId = items[0].json.id_story;\n\nlet md = \"# RELATO COMPLETO\\n\\n\";\n\nitems\n  .sort((a,b) => a.json.act_number - b.json.act_number)\n  .forEach(item => {\n\n    md += \"## ACTO \" + item.json.act_number + \"\\n\\n\";\n    md += item.json.chapter + \"\\n\\n---\\n\\n\";\n\n});\n\nreturn [{\n  json: {\n    md_text: md,\n    story_id: storyId,\n    nombre_archivo: \"relato_\" + storyId + \".md\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1296,
        -80
      ],
      "id": "eb35c902-32ed-4266-8ea7-2f0309886ae8",
      "name": "persiste_cinco_capitulos"
    },
    {
      "parameters": {
        "jsCode": "const base = $input.first().json;\nconst text = base.story_prompt;\n\n// 1 separar contexto y actos\nconst [contextPart, actsPart] = text.split(/\\n---\\n/);\n\n// 2 dividir actos por encabezado\nconst sections = actsPart.split(/^\\s*\\*\\*Acto\\s+/gm).slice(1);\n\nconst actos = sections.map(section => {\n\n  // extraer numero de acto\n  const numMatch = section.match(/^(\\d+)/);\n  const act_number = numMatch ? Number(numMatch[1]) : null;\n\n  // extraer fase narrativa entre parentesis\n  const phaseMatch = section.match(/\\((.*?)\\)/);\n  const arc_phase = phaseMatch ? phaseMatch[1].trim() : null;\n\n  // remover encabezado\n  const content = section\n    .replace(/^\\d+[^\\n]*\\n?/, \"\")\n    .trim();\n\n  return {\n    json: {\n      act_number,\n      arc_phase,\n      act_mission: content,\n      base_context: {\n        id_story: base.id_story,\n        story_name: base.story_name,\n        total_acts: base.total_acts,\n        system_prompt: base.system_prompt,\n        story_context: contextPart.trim()\n      }\n    }\n  };\n\n});\n\nreturn actos;"
      },
