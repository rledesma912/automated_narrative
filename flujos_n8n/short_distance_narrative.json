    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COALESCE(a.id_story, '') AS id_story,\n  COALESCE(a.summary, '') AS accumulated_summary,\n  COALESCE(a.memory, '') AS accumulated_memory\nFROM stories s\nLEFT JOIN (\n  SELECT\n    id_story,\n    summary,\n    memory\n  FROM story_acts\n  WHERE id_story = '{{ $json.id_story }}'\n  ORDER BY act_number DESC\n  LIMIT 1\n) a\nON s.id_story = a.id_story\nWHERE s.id_story = '{{ $json.id_story }}'\nLIMIT 1;",
        "options": {}
