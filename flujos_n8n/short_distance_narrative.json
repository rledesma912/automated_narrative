    {
      "parameters": {
        "promptType": "define",
        "text": "=Reglas:\n- Máximo 180 palabras.\n- No escribir como relato.\n- No usar estilo literario.\n- No agregar nada nuevo.\n- Solo hechos confirmados en el texto.\n\nFormato obligatorio:\nUBICACIÓN ACTUAL:\nPERSONAJES PRESENTES:\nHECHOS IMPORTANTES:\nOBJETOS RELEVANTES:\nCAMBIOS EN EL ENTORNO:\nESTADO EMOCIONAL DEL PROTAGONISTA:\n\nACTO:\n{{ $('gen_act').item.json.text }}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        992,
        144
      ],
      "id": "905a4ded-f2a7-4b94-8792-a6dcbe4fa49a",
      "name": "gen_memory"
    },
    {
      "parameters": {
        "jsCode": "//const item = $input.first().json;\nconst data = $json;\n\nconst context = data.story_context;\nconst mission = data.act_mission;\nconst act_number = data.act_number;\nconst arcPhase = data.arc_phase;\n\nconst memory = data.accumulated_memory || \"\";\nconst summary = data.accumulated_summary|| \"\";\n\nlet prompt = \"\";\n\nprompt += \"CONTEXTO DEL RELATO\\n\";\nprompt += context + \"\\n\\n\";\n\n// resumen solo si existe\nif (summary) {\n  prompt += \"RESUMEN DEL ACTO ANTERIOR\\n\";\n  prompt += summary + \"\\n\\n\";\n}\n\n// memoria solo si existe\nif (memory) {\n  prompt += \"MEMORIA NARRATIVA\\n\";\n  prompt += memory + \"\\n\\n\";\n}\n\nprompt += \"FASE DEL ARCO NARRATIVO\\n\";\nprompt += arcPhase + \"\\n\\n\";\n\nprompt += \"MISIÓN DEL ACTO\\n\";\nprompt += mission + \"\\n\\n\";\n\nif (act_number > 1) {\n  // aquí agregamos la regla crítica del pipeline\n  prompt += `REGLAS DE CONTINUIDAD\\n\n 1. Usa el RESUMEN DEL ACTO ANTERIOR como punto de partida narrativo.\\n\n 2. El capítulo debe comenzar inmediatamente después de ese momento.\\n\n 3. Respeta la MEMORIA NARRATIVA: contiene hechos, personajes y lugares ya  establecidos.\\n\n 4. No contradigas ni cambies información almacenada en la memoria.\\n\n 5. No reinicies la historia ni repitas escenas ya narradas.\\n\n 6. Avanza el relato desde la última situación descrita en el resumen.\\n\n  `;\n}\n\nif (act_number === 1) {\n  prompt += `\nINICIO DE LA HISTORIA\\n\nEste es el primer capítulo.\\n\nNo existe un acto anterior.\\n\nComienza la narración desde el contexto inicial descrito arriba.\\n\n`;\n}\n\nprompt += \"Escribe el capítulo siguiendo todas las instrucciones anteriores.\";\n\nreturn [\n  {\n    json: {\n      prompt\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
