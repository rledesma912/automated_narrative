    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet sistema = \"\";\nlet historia = \"\";\nlet config = {};\n\nfor (let i = 0; i < items.length; i++) {\n\n  const item = items[i];\n\n  // configuración proveniente de valores_calculados\n  if (item.json && item.json.total_acts) {\n    config = item.json;\n  }\n\n  // lectura de archivos binarios\n  if (item.binary && item.binary.data) {\n\n    const fileName = item.binary.data.fileName || \"\";\n    const buffer = await this.helpers.getBinaryDataBuffer(i, \"data\");\n    const text = buffer.toString(\"utf8\").trim();\n\n    if (fileName.includes(\"system_prompt\")) {\n      sistema = text;\n    }\n\n    if (fileName.includes(\".md\") && !fileName.includes(\"story_prompt\")) {\n      historia = text;\n    }\n  }\n}\n\nreturn [{\n  json: {\n    id_story: config.id_story,\n    story_name: config.story_name,\n    total_acts: config.total_acts,\n    system_prompt: sistema,\n    story_prompt: historia,\n    accumulated_summary: \"\",\n    accumulated_memory: \"\"\n  }\n}];"
      },
