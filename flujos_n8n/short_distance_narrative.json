      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT  id_story, act_number, chapter\nFROM story_acts \nWHERE id_story = '{{ $('prepare_items').item.json.id_story }}' \nORDER BY act_number ASC;",
        "options": {}
