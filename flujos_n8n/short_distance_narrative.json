        "query": "INSERT INTO story_acts\n(\nid_story,\nact_number,\narc_phase,\nchapter,\nsummary,\nmemory\n)\nVALUES\n(\n'{{ $('build_extract_prompt').item.json.id_story }}',\n{{ $('build_extract_prompt').item.json.act_number }},\n'{{ $('build_extract_prompt').item.json.arc_phase }}',\n'{{$node[\"gen_act\"].json.text}}',\n'{{ JSON.parse($node[\"extract_story_state\"].json.text).summary }}',\n'{{ JSON.stringify(JSON.parse($node[\"extract_story_state\"].json.text).memory) }}'\n);",
        "options": {}
