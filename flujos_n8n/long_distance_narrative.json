      "parameters": {
        "jsCode": "const items = $input.all();  // Rows de SQL\n\nconst storyId = $node[\"prepare_items\"].json.story_id;\n\nlet md = \"# RELATO COMPLETO\\n\\n\";\n\nitems.forEach(item => {\n  md += \"## ACTO \" + item.json.acto_numero + \"\\n\\n\";\n  md += item.json.contenido + \"\\n\\n---\\n\\n\";\n});\n\nreturn [{\n  json: {\n    md_text: md,\n    story_id: storyId,\n    nombre_archivo: \"relato_\" + storyId + \".md\"\n  }\n}];"
