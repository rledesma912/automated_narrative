      ],
      "id": "8781aa37-60d7-41ee-86d6-e40028e791da",
      "name": "Loop Over Items"
    },
    {
      "parameters": {
        "jsCode": "const base = $input.first().json; // viene de gen_memory con .text = memoria\nconst summarized = $node[\"summarize_act\"].json; // tiene resumen en .text\nconst inserted = $node[\"insert_act_in_table\"].json; // tiene acto_numero, story_id\n\n// Acumular resumen (reemplaza por el nuevo — es el resumen del acto actual)\nconst resumenNuevo = (summarized.text || \"\").trim();\n\n// Acumular memoria (concatena con la anterior)\nconst memoriaAnterior = (inserted.memoria_estructurada_acumulada || \"\").trim();\nconst memoriaActual = \"ACTO \" + inserted.acto_numero + \":\\n\" + (base.text || \"\").trim();\nconst memoriaAcumulada = memoriaAnterior\n  ? memoriaAnterior + \"\\n\\n\" + memoriaActual\n  : memoriaActual;\n\nreturn [{\n  json: {\n    ...inserted,\n    resumen_narrativo_acumulado: resumenNuevo,\n    memoria_estructurada_acumulada: memoriaAcumulada\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        736,
        240
      ],
      "id": "17f223f2-b369-43f7-83aa-e0d2904a01a0",
