    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Reglas:\n- Máximo 180 palabras.\n- No escribir como relato.\n- No usar estilo literario.\n- No agregar nada nuevo.\n- Solo hechos confirmados en el texto.\n\nFormato obligatorio:\nUBICACIÓN ACTUAL:\nPERSONAJES PRESENTES:\nHECHOS IMPORTANTES:\nOBJETOS RELEVANTES:\nCAMBIOS EN EL ENTORNO:\nESTADO EMOCIONAL DEL PROTAGONISTA:\n\nACTO:\n{{ $('insert_act_in_table').item.json.contenido }}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        432,
        80
      ],
      "id": "905a4ded-f2a7-4b94-8792-a6dcbe4fa49a",
      "name": "gen_memory"
    },
    {
      "parameters": {
        "jsCode": "const state = $input.first().json;\n\nconst resumen = (state.resumen_narrativo_acumulado || \"\").trim();\nconst memoria = (state.memoria_estructurada_acumulada || \"\").trim();\nconst esPrimerActo = !resumen && !memoria;\n\nreturn [{\n  json: {\n    ...state,\n    prompt_text: `\nCONTEXTO FIJO DE LA HISTORIA:\n${state.historia_base_text}\n\n---\n\nESTADO NARRATIVO ACUMULADO:\n\nRESUMEN CLAVE:\n${esPrimerActo ? \"SIN ACTOS PREVIOS.\" : resumen}\n\nMEMORIA ESTRUCTURADA:\n${esPrimerActo ? \"SIN MEMORIA PREVIA.\" : memoria}\n\n---\n\nACTO ACTUAL: ${state.acto_numero}\n\nMISIÓN ESPECÍFICA DEL ACTO:\n${state.mision_del_acto}\n\n---\n\nINSTRUCCIÓN DE CONTINUIDAD:\n${esPrimerActo ? \"Este es el inicio absoluto del relato.\" : \"Continúa orgánicamente desde el estado acumulado.\"}\n`.trim()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -416,
        80
      ],
      "id": "9f9a2b3f-3d85-4c42-9da3-83126d04c62a",
      "name": "build_prompt"
    },
    {
      "parameters": {
        "jsCode": "const base = $input.first().json;\n\n// Verificación rápida\nif (!base.sistema_text) {\n  throw new Error(\"sistema_text vacío — init_story_state no pasó los datos correctamente\");\n}\n\nconst actos = [];\nfor (let i = 1; i <= base.total_actos; i++) {\n  actos.push({\n    json: {\n      acto_numero: i,\n      total_actos: base.total_actos,\n      sistema_text: base.sistema_text,\n      historia_base_text: base.historia_base_text,\n      story_id: base.story_id,\n      mision_del_acto: base.mision_del_acto,\n      resumen_narrativo_acumulado: \"\",\n      memoria_estructurada_acumulada: \"\"\n    }\n  });\n}\n\nreturn actos;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -848,
        224
      ],
      "id": "9cf8bd54-6892-4286-87e0-82f1de590155",
      "name": "prepare_items"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet sistema = \"\";\nlet historia = \"\";\nlet config = {};\n\n// recorrer items\nfor (let i = 0; i < items.length; i++) {\n\n  const item = items[i];\n\n  // detectar item de configuración\n  if (item.json && item.json.total_actos) {\n    config = item.json;\n  }\n\n  // leer binarios\n  if (item.binary && item.binary.data) {\n\n    const fileName = item.binary.data.fileName || \"\";\n\n    const buffer = await this.helpers.getBinaryDataBuffer(i, \"data\");\n    const text = buffer.toString(\"utf8\").trim();\n\n    if (fileName.includes(\"system_prompt\")) {\n      sistema = text;\n    }\n\n    if (fileName.includes(config.story_filename || \"\")) {\n      historia = text;\n    }\n  }\n}\n\nreturn [{\n  json: {\n    total_actos: config.total_actos,\n    sistema_text: sistema,\n    historia_base_text: historia,\n    resumen_narrativo_acumulado: \"\",\n    memoria_estructurada_acumulada: \"\",\n    story_id: config.story_id,\n    mision_del_acto: \"\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -896,
        -32
      ],
      "id": "c91c7ec0-a5fa-4b3c-8f31-f7dce16c8f26",
