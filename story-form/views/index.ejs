<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Constructor de Historia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Crimson+Pro:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="grain"></div>

<div class="app-shell">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <span class="brand-icon">✦</span>
      <span class="brand-name">Narrative<br>Builder</span>
    </div>

    <nav class="step-nav">
      <button class="step-btn active" data-step="1">
        <span class="step-num">01</span>
        <span class="step-label">La historia</span>
      </button>
      <button class="step-btn" data-step="2">
        <span class="step-num">02</span>
        <span class="step-label">El mundo</span>
      </button>
      <button class="step-btn" data-step="3">
        <span class="step-num">03</span>
        <span class="step-label">Las reglas</span>
      </button>
      <button class="step-btn" data-step="4">
        <span class="step-num">04</span>
        <span class="step-label">Los actos</span>
      </button>
      <button class="step-btn" data-step="5">
        <span class="step-num">05</span>
        <span class="step-label">Guardar</span>
      </button>
    </nav>

    <div class="sidebar-progress">
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <span class="progress-label" id="progressLabel">Paso 1 de 5</span>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main-content">

    <!-- SUCCESS STATE -->
    <% if (saved) { %>
    <div class="success-screen">
      <div class="success-icon">✦</div>
      <h1 class="success-title">Historia guardada</h1>
      <p class="success-path"><%= saved.filename %></p>
      <pre class="success-preview"><%= preview %></pre>
      <a href="/" class="btn-primary">Crear otra historia</a>
    </div>
    <% } else { %>

    <!-- ERRORS -->
    <% if (errors.length > 0) { %>
    <div class="error-banner">
      <strong>Hay campos incompletos:</strong>
      <ul>
        <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
      </ul>
    </div>
    <% } %>

    <form id="storyForm" action="/save" method="POST">

      <!-- ═══════════════════════════════════════
           PASO 1 — La historia
      ═══════════════════════════════════════ -->
      <section class="step-panel active" data-panel="1">
        <div class="panel-header">
          <span class="panel-num">01</span>
          <h2 class="panel-title">La historia</h2>
          <p class="panel-desc">Empezá por lo básico: cómo se llama y de qué trata.</p>
        </div>

        <div class="field-group">
          <label class="field-label" for="story_name">
            Nombre de la historia
            <span class="field-hint">Este nombre se usa para generar el nombre del archivo</span>
          </label>
          <input
            type="text"
            id="story_name"
            name="story_name"
            class="field-input"
            placeholder="Ej: El otro pueblo"
            value="<%= typeof formData !== 'undefined' && formData.story_name ? formData.story_name : '' %>"
            autocomplete="off"
          >
          <span class="filename-preview" id="filenamePreview"></span>
        </div>

        <div class="field-group">
          <label class="field-label" for="genero">
            Género
            <span class="field-hint">El género principal y, si querés, uno secundario</span>
          </label>
          <input
            type="text"
            id="genero"
            name="genero"
            class="field-input"
            placeholder="Ej: Terror sobrenatural. Viaje a otra dimensión."
            value="<%= typeof formData !== 'undefined' && formData.genero ? formData.genero : '' %>"
          >
          <div class="genre-chips">
            <button type="button" class="chip" data-target="genero" data-val="Terror psicológico">Terror psicológico</button>
            <button type="button" class="chip" data-target="genero" data-val="Terror sobrenatural">Terror sobrenatural</button>
            <button type="button" class="chip" data-target="genero" data-val="Suspenso y terror">Suspenso y terror</button>
            <button type="button" class="chip" data-target="genero" data-val="Terror y ciencia ficción">Terror y sci-fi</button>
            <button type="button" class="chip" data-target="genero" data-val="Terror folclórico">Terror folclórico</button>
          </div>
        </div>

        <div class="step-nav-btns">
          <div></div>
          <button type="button" class="btn-primary next-btn" data-next="2">
            Siguiente <span>→</span>
          </button>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           PASO 2 — El mundo
      ═══════════════════════════════════════ -->
      <section class="step-panel" data-panel="2">
        <div class="panel-header">
          <span class="panel-num">02</span>
          <h2 class="panel-title">El mundo</h2>
          <p class="panel-desc">Los personajes, los lugares y el argumento completo.</p>
        </div>

        <div class="field-group">
          <label class="field-label" for="protagonistas">
            Protagonistas
            <span class="field-hint">Nombre, edad aproximada, personalidad y cómo habla cada uno</span>
          </label>
          <textarea
            id="protagonistas"
            name="protagonistas"
            class="field-textarea"
            rows="4"
            placeholder="Ej: Tadeo (13 años): hermano mayor, protector y valiente, habla con seguridad. Valentino (9 años): hermano menor, ingenuo y temeroso, llora fácil."
          ><%= typeof formData !== 'undefined' && formData.protagonistas ? formData.protagonistas : '' %></textarea>
          <div class="char-counter"><span id="cc-protagonistas">0</span> palabras</div>
        </div>

        <div class="field-group">
          <label class="field-label" for="escenarios">
            Escenarios
            <span class="field-hint">Listá los lugares con una descripción del ambiente y sensación de cada uno</span>
          </label>
          <textarea
            id="escenarios"
            name="escenarios"
            class="field-textarea"
            rows="4"
            placeholder="Ej: Casa de campo cálida y familiar. Camino de tierra entre pastizales altos al anochecer. Centro de pueblo desierto con faroles que apenas alumbran."
          ><%= typeof formData !== 'undefined' && formData.escenarios ? formData.escenarios : '' %></textarea>
          <div class="char-counter"><span id="cc-escenarios">0</span> palabras</div>
        </div>

        <div class="field-group">
          <label class="field-label" for="sinopsis">
            Sinopsis
            <span class="field-hint">La historia completa en 3-4 oraciones: inicio, problema central y cómo termina</span>
          </label>
          <textarea
            id="sinopsis"
            name="sinopsis"
            class="field-textarea"
            rows="5"
            placeholder="Ej: Dos hermanos van al pueblo al anochecer. Al tomar un atajo quedan atrapados en una versión siniestra del pueblo. Escapan aterrorizados y llegan a casa sanos pero sus padres no les creen."
          ><%= typeof formData !== 'undefined' && formData.sinopsis ? formData.sinopsis : '' %></textarea>
          <div class="char-counter"><span id="cc-sinopsis">0</span> palabras</div>
        </div>

        <div class="step-nav-btns">
          <button type="button" class="btn-secondary prev-btn" data-prev="1">← Anterior</button>
          <button type="button" class="btn-primary next-btn" data-next="3">Siguiente →</button>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           PASO 3 — Las reglas
      ═══════════════════════════════════════ -->
      <section class="step-panel" data-panel="3">
        <div class="panel-header">
          <span class="panel-num">03</span>
          <h2 class="panel-title">Las reglas de la historia</h2>
          <p class="panel-desc">
            Son los hechos que <strong>nunca pueden cambiar</strong> sin importar lo que pase en cada capítulo.<br>
            Agregá entre 4 y 6 reglas. Son la columna vertebral que la IA respeta en todos los actos.
          </p>
        </div>

        <div class="rules-container" id="rulesContainer">
          <div class="rule-row">
            <span class="rule-num">1</span>
            <input type="text" name="reglas" class="field-input rule-input" placeholder="Ej: Valentino nunca actúa con valentía" value="">
            <button type="button" class="rule-remove" title="Eliminar">×</button>
          </div>
          <div class="rule-row">
            <span class="rule-num">2</span>
            <input type="text" name="reglas" class="field-input rule-input" placeholder="Ej: El campo de pastizales es el único portal de entrada y salida" value="">
            <button type="button" class="rule-remove" title="Eliminar">×</button>
          </div>
          <div class="rule-row">
            <span class="rule-num">3</span>
            <input type="text" name="reglas" class="field-input rule-input" placeholder="Ej: El villano no aparece hasta el Acto 3" value="">
            <button type="button" class="rule-remove" title="Eliminar">×</button>
          </div>
          <div class="rule-row">
            <span class="rule-num">4</span>
            <input type="text" name="reglas" class="field-input rule-input" placeholder="Ej: Al final los adultos no creen lo que les cuentan" value="">
            <button type="button" class="rule-remove" title="Eliminar">×</button>
          </div>
        </div>

        <button type="button" class="btn-add-rule" id="addRuleBtn">
          + Agregar regla
        </button>

        <div class="step-nav-btns">
          <button type="button" class="btn-secondary prev-btn" data-prev="2">← Anterior</button>
          <button type="button" class="btn-primary next-btn" data-next="4">Siguiente →</button>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           PASO 4 — Los actos
      ═══════════════════════════════════════ -->
      <section class="step-panel" data-panel="4">
        <div class="panel-header">
          <span class="panel-num">04</span>
          <h2 class="panel-title">Los actos</h2>
          <p class="panel-desc">
            Describí qué pasa en cada capítulo. No necesitás escribirlo como un relato —<br>
            con oraciones directas y concretas alcanza. La IA lo convierte en narrativa.
          </p>
        </div>

        <!-- Acto 1 -->
        <div class="act-block" data-act="1">
          <div class="act-header" data-toggle="1">
            <div class="act-meta">
              <span class="act-tag">Acto 1</span>
              <span class="act-name">Situación inicial</span>
            </div>
            <span class="act-hint">Tono cotidiano — sin horror todavía. Presentá el mundo normal de los protagonistas.</span>
            <span class="act-arrow">▾</span>
          </div>
          <div class="act-body open">
            <textarea name="acto1" class="field-textarea act-textarea" rows="6"
              placeholder="¿Dónde están? ¿Qué tienen que hacer? ¿Cómo es la relación entre los personajes? Establecé la calma antes de la tormenta."
            ><%= typeof formData !== 'undefined' && formData.acto1 ? formData.acto1 : '' %></textarea>
            <div class="char-counter"><span class="cc-act">0</span> palabras</div>
          </div>
        </div>

        <!-- Acto 2 -->
        <div class="act-block" data-act="2">
          <div class="act-header" data-toggle="2">
            <div class="act-meta">
              <span class="act-tag">Acto 2</span>
              <span class="act-name">Conflicto inicial</span>
            </div>
            <span class="act-hint">Algo empieza a estar mal. El miedo comienza, pero todavía hay dudas.</span>
            <span class="act-arrow">▾</span>
          </div>
          <div class="act-body">
            <textarea name="acto2" class="field-textarea act-textarea" rows="6"
              placeholder="¿Qué primeros signos extraños notan los personajes? ¿Qué los hace dudar o asustarse? ¿Qué deciden hacer?"
            ><%= typeof formData !== 'undefined' && formData.acto2 ? formData.acto2 : '' %></textarea>
            <div class="char-counter"><span class="cc-act">0</span> palabras</div>
          </div>
        </div>

        <!-- Acto 3 -->
        <div class="act-block" data-act="3">
          <div class="act-header" data-toggle="3">
            <div class="act-meta">
              <span class="act-tag">Acto 3</span>
              <span class="act-name">Falsa calma</span>
            </div>
            <span class="act-hint">Creen que pueden controlarlo — pero algo los contradice. El peligro se vuelve concreto.</span>
            <span class="act-arrow">▾</span>
          </div>
          <div class="act-body">
            <textarea name="acto3" class="field-textarea act-textarea" rows="6"
              placeholder="¿Qué momento de alivio tienen? ¿Qué lo rompe? ¿Cuál es la primera amenaza real y concreta?"
            ><%= typeof formData !== 'undefined' && formData.acto3 ? formData.acto3 : '' %></textarea>
            <div class="char-counter"><span class="cc-act">0</span> palabras</div>
          </div>
        </div>

        <!-- Acto 4 -->
        <div class="act-block" data-act="4">
          <div class="act-header" data-toggle="4">
            <div class="act-meta">
              <span class="act-tag">Acto 4</span>
              <span class="act-name">Crisis mayor</span>
            </div>
            <span class="act-hint">Todo se descontrola. Mayor tensión y movimiento. El obstáculo que parece insuperable.</span>
            <span class="act-arrow">▾</span>
          </div>
          <div class="act-body">
            <textarea name="acto4" class="field-textarea act-textarea" rows="6"
              placeholder="¿Qué los pone en peligro real? ¿Qué deben hacer para sobrevivir? ¿Quién o qué los amenaza directamente?"
            ><%= typeof formData !== 'undefined' && formData.acto4 ? formData.acto4 : '' %></textarea>
            <div class="char-counter"><span class="cc-act">0</span> palabras</div>
          </div>
        </div>

        <!-- Acto 5 -->
        <div class="act-block" data-act="5">
          <div class="act-header" data-toggle="5">
            <div class="act-meta">
              <span class="act-tag">Acto 5</span>
              <span class="act-name">Clímax y resolución</span>
            </div>
            <span class="act-hint">El punto más alto y el cierre. Respetá las reglas de la historia.</span>
            <span class="act-arrow">▾</span>
          </div>
          <div class="act-body">
            <textarea name="acto5" class="field-textarea act-textarea" rows="6"
              placeholder="¿Cómo escapan o superan el peligro? ¿Qué pasa después? ¿Hay consecuencias? Cerrá todos los hilos abiertos."
            ><%= typeof formData !== 'undefined' && formData.acto5 ? formData.acto5 : '' %></textarea>
            <div class="char-counter"><span class="cc-act">0</span> palabras</div>
          </div>
        </div>

        <div class="step-nav-btns">
          <button type="button" class="btn-secondary prev-btn" data-prev="3">← Anterior</button>
          <button type="button" class="btn-primary next-btn" data-next="5">Revisar →</button>
        </div>
      </section>

      <!-- ═══════════════════════════════════════
           PASO 5 — Guardar
      ═══════════════════════════════════════ -->
      <section class="step-panel" data-panel="5">
        <div class="panel-header">
          <span class="panel-num">05</span>
          <h2 class="panel-title">Guardar historia</h2>
          <p class="panel-desc">Revisá el archivo que se va a generar y guardalo cuando estés conforme.</p>
        </div>

        <div class="preview-panel">
          <div class="preview-toolbar">
            <span class="preview-label">Vista previa del archivo .md</span>
            <button type="button" id="refreshPreview" class="btn-preview-refresh">↺ Actualizar</button>
          </div>
          <pre class="preview-content" id="mdPreview">Completá los pasos anteriores para ver la vista previa...</pre>
        </div>

        <div class="save-row">
          <button type="button" class="btn-secondary prev-btn" data-prev="4">← Anterior</button>
          <button type="submit" class="btn-save">
            <span class="save-icon">✦</span>
            Guardar historia
          </button>
        </div>
      </section>

    </form>
    <% } %>
  </main>
</div>

<script src="/js/app.js"></script>
</body>
</html>
